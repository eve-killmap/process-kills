# Database connection URL (required to run the service).
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://username:password@127.0.0.1:5432/database

# Redis server for the live kill stream (required for live streaming to the
# backend; the service still ingests kills without it).
REDIS_URL=redis://localhost:6379

# Contact-bearing User-Agent for ESI/zKillboard requests, per CCP API rules.
USER_AGENT=eve-killmap:process-kills/1.0.0 (your-contact@example.com)

# Log file path (defaults to ./process-kills.log).
LOG_FILE=process-kills.log

# Optional: overrides logging.level from config.yml.
# LOG_LEVEL=INFO

# Optional: Working directory for the backfill script.
# DATA_DIR=./data
